# SPA: serve index.html for client-side routes (React Router)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don’t rewrite real files or directories (assets, etc.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Everything else → index.html
  RewriteRule ^ index.html [L]
</IfModule>
