{
  "name": "vet-pharmacy-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "start": "node server/index.js",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand",
    "test:e2e": "STAGING_MODE=true playwright test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:local": "concurrently \"npm run server\" \"npm run dev\"",
    "seed:products": "node server/seed-products.js",
    "add-missing-products": "node server/add-missing-products.js",
    "remove-duplicate-products": "node server/remove-duplicate-products.js",
    "db:backup": "node server/scripts/backup-db.js",
    "deploy": "node deploy.js",
    "sync:product-images": "node scripts/sync-product-images-from-legacy-supabase.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "@tanstack/react-query": "^5.59.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "claude-code": "^1.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.454.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "ftp-deploy": "^2.4.7",
    "globals": "^15.11.0",
    "jest": "^30.3.0",
    "postcss": "^8.4.47",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.14",
    "ts-jest": "^29.4.9",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
